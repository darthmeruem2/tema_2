<div class="related-products--root">
  <div class="related-products--wrapper">

    <div class="related-products--header">
      <h2 class="related-products--title">{{ section.settings.heading | default: 'BOOST YOUR ROUTINE' | upcase }}</h2>
    </div>

    <div
      class="related-products--grid"
      data-related-products
      data-product-id="{{ product.id }}"
      data-limit="{{ section.settings.limit | default: 4 }}"
    >
      {%- comment -%}
        Content is populated by components.js via Shopify Recommendations API.
        Static fallback shown below while JS loads.
      {%- endcomment -%}
      {%- for i in (1..4) -%}
        <div class="product-card--root" style="opacity:0.3;">
          <div class="product-card--image-wrapper" style="background:var(--bg-color--light); aspect-ratio:4/5;"></div>
        </div>
      {%- endfor -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Related Products",
  "tag": "section",
  "class": "section-related-products",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Boost Your Routine"
    },
    {
      "type": "range",
      "id": "limit",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Number of products",
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Related Products",
      "settings": {
        "heading": "Boost Your Routine"
      }
    }
  ]
}
{% endschema %}
