<div class="main-collection--root">

  <div class="main-collection--header">
    <div>
      <h1 class="main-collection--title">
        {%- if search.performed -%}
          RESULTS FOR "{{ search.terms | escape | upcase }}"
        {%- else -%}
          SEARCH
        {%- endif -%}
      </h1>
    </div>
    {%- if search.performed -%}
      <span class="main-collection--count">{{ search.results_count }} RESULTS</span>
    {%- endif -%}
  </div>

  <!-- Search Form -->
  <form action="/search" method="get" style="margin-bottom:var(--layout--spacing-large);">
    <input type="hidden" name="type" value="product">
    <div style="display:flex; max-width:500px;">
      <input
        type="search"
        name="q"
        value="{{ search.terms | escape }}"
        placeholder="SEARCH PRODUCTS..."
        style="height:var(--input--height); flex:1; padding:var(--input--padding); border:1px solid rgba(0,0,0,0.15); border-right:none; font-family:var(--font--paragraph--family); font-size:var(--font--nav--size); text-transform:uppercase; background:transparent; outline:none;"
        aria-label="Search"
        autofocus
      >
      <button
        type="submit"
        style="height:var(--button--height); padding:var(--button--padding); background:var(--color--body); color:#fff; border:1px solid var(--color--body); font-family:var(--font--nav--family); font-size:var(--font--button--size); text-transform:uppercase; letter-spacing:0.08em; cursor:pointer; white-space:nowrap;"
      >
        SEARCH
      </button>
    </div>
  </form>

  {%- if search.performed -%}
    {%- if search.results_count > 0 -%}
      <div class="main-collection--grid">
        {%- for result in search.results -%}
          {%- if result.object_type == 'product' -%}
            {%- render 'product-card', product: result -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- else -%}
      <p class="main-collection--empty">
        No results found for "{{ search.terms | escape | upcase }}". Try a different search term.
      </p>
      <a href="/collections/all" class="btn btn--1" style="margin-top:var(--layout--spacing-medium);">SHOP ALL PRODUCTS</a>
    {%- endif -%}
  {%- endif -%}

</div>

{% schema %}
{
  "name": "Search",
  "tag": "section",
  "settings": []
}
{% endschema %}
