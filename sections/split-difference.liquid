<div class="split-difference split-difference--image-{{ section.settings.image_position }}">

  <div class="split-difference--image-col">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', alt: section.settings.heading, class: 'split-difference--img' }}
    {%- else -%}
      <div class="img-placeholder">The SHIEH Difference</div>
    {%- endif -%}
  </div>

  <div class="split-difference--content-col">
    {%- if section.settings.overline != blank -%}
      <span class="split-difference--overline">{{ section.settings.overline }}</span>
    {%- endif -%}

    <h2 class="split-difference--heading">{{ section.settings.heading }}</h2>

    {%- if section.settings.body_1 != blank -%}
      <p class="split-difference--body">{{ section.settings.body_1 }}</p>
    {%- endif -%}

    {%- if section.settings.body_2 != blank -%}
      <p class="split-difference--body">{{ section.settings.body_2 }}</p>
    {%- endif -%}

    {%- if section.settings.cta_text != blank -%}
      <a href="{{ section.settings.cta_link }}" class="btn btn--primary split-difference--cta">
        {{ section.settings.cta_text }}
      </a>
    {%- endif -%}
  </div>

</div>

{% schema %}
{
  "name": "Split Difference",
  "tag": "div",
  "class": "split-difference-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "overline",
      "label": "Overline",
      "default": "The SHIEH Difference"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Clinical Actives. No Hiding."
    },
    {
      "type": "textarea",
      "id": "body_1",
      "label": "Body Paragraph 1",
      "default": "Most skincare brands list niacinamide on the label. Few will tell you it's at 0.1% — a concentration too low to do anything. SHIEH formulates at clinically active thresholds and publishes every number."
    },
    {
      "type": "textarea",
      "id": "body_2",
      "label": "Body Paragraph 2",
      "default": "The result: £24 products that outperform £80 competitors on paper and in practice. Not because we're cheaper. Because we stopped paying for the opacity."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Text",
      "default": "Discover More"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Link"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image Position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    }
  ],
  "presets": [
    {
      "name": "Split Difference"
    }
  ]
}
{% endschema %}
