<div class="main-page--root" style="max-width:760px;">

  <div style="display:flex; align-items:baseline; justify-content:space-between; margin-bottom:var(--layout--spacing-large);">
    <h1 class="main-page--title" style="margin-bottom:0;">PEDIDO {{ order.name }}</h1>
    <a href="/account" style="font-size:10px; text-transform:uppercase; letter-spacing:0.08em; color:var(--color--gray);">
      ← MINHA CONTA
    </a>
  </div>

  <p style="font-size:10px; text-transform:uppercase; color:var(--color--gray); margin-bottom:var(--layout--spacing-medium);">
    {{ order.created_at | date: '%d de %B de %Y' | upcase }}
    &nbsp;·&nbsp;
    {{ order.financial_status_label | upcase }}
  </p>

  <!-- Line items -->
  <div style="margin-bottom:var(--layout--spacing-large);">
    {%- for line_item in order.line_items -%}
      <div style="display:grid; grid-template-columns:80px 1fr auto; gap:16px; padding:16px 0; border-bottom:1px solid rgba(0,0,0,0.06); align-items:start;">
        {%- if line_item.image -%}
          <div style="aspect-ratio:1; overflow:hidden; background:var(--bg-color--light);">
            <img
              src="{{ line_item.image | image_url: width: 160 }}"
              alt="{{ line_item.title | escape }}"
              width="80" height="80"
              style="width:100%; height:100%; object-fit:cover;"
            >
          </div>
        {%- else -%}
          <div style="aspect-ratio:1; background:var(--bg-color--light);"></div>
        {%- endif -%}
        <div>
          <p style="font-size:11px; font-weight:700; text-transform:uppercase; margin-bottom:4px;">{{ line_item.title }}</p>
          {%- if line_item.variant.title != 'Default Title' -%}
            <p style="font-size:10px; text-transform:uppercase; color:var(--color--gray); margin-bottom:4px;">{{ line_item.variant.title }}</p>
          {%- endif -%}
          <p style="font-size:10px; text-transform:uppercase; color:var(--color--gray);">QTD: {{ line_item.quantity }}</p>
        </div>
        <div style="text-align:right;">
          <p style="font-size:11px; font-weight:700; text-transform:uppercase;">{{ line_item.final_line_price | money }}</p>
        </div>
      </div>
    {%- endfor -%}
  </div>

  <!-- Order summary -->
  <div style="max-width:320px; margin-left:auto;">
    <div style="display:flex; justify-content:space-between; font-size:11px; text-transform:uppercase; padding:8px 0; color:var(--color--gray);">
      <span>Subtotal</span>
      <span>{{ order.subtotal_price | money }}</span>
    </div>
    {%- for discount in order.discounts -%}
      <div style="display:flex; justify-content:space-between; font-size:11px; text-transform:uppercase; padding:8px 0; color:var(--color--accent-1);">
        <span>Desconto</span>
        <span>-{{ discount.amount | money }}</span>
      </div>
    {%- endfor -%}
    <div style="display:flex; justify-content:space-between; font-size:11px; text-transform:uppercase; padding:8px 0; color:var(--color--gray);">
      <span>Envio</span>
      <span>
        {%- if order.shipping_price == 0 -%}
          GRÁTIS
        {%- else -%}
          {{ order.shipping_price | money }}
        {%- endif -%}
      </span>
    </div>
    <div style="display:flex; justify-content:space-between; font-size:13px; font-weight:700; text-transform:uppercase; padding:16px 0; border-top:1px solid rgba(0,0,0,0.08); margin-top:8px;">
      <span>Total</span>
      <span>{{ order.total_price | money }}</span>
    </div>
  </div>

  <!-- Shipping address -->
  {%- if order.shipping_address -%}
    <div style="margin-top:var(--layout--spacing-large); padding-top:var(--layout--spacing-medium); border-top:1px solid rgba(0,0,0,0.06);">
      <h2 style="font-size:12px; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; margin-bottom:12px;">
        ENDEREÇO DE ENTREGA
      </h2>
      <address style="font-style:normal; font-size:11px; text-transform:uppercase; color:var(--color--body--light); line-height:1.8;">
        {{ order.shipping_address.name }}<br>
        {{ order.shipping_address.address1 }}<br>
        {%- if order.shipping_address.address2 != blank -%}
          {{ order.shipping_address.address2 }}<br>
        {%- endif -%}
        {{ order.shipping_address.city }}, {{ order.shipping_address.zip }}<br>
        {{ order.shipping_address.country }}
      </address>
    </div>
  {%- endif -%}

</div>

{% schema %}
{
  "name": "Order",
  "tag": "section",
  "settings": []
}
{% endschema %}
