<section class="hero-split">
  <!-- LEFT: hero image/gradient + conteúdo no rodapé -->
  <div class="hero-split--left">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 1400 | image_tag: loading: 'eager', class: 'hero-split--bg-img', alt: '', fetchpriority: 'high' }}
    {%- else -%}
      <div class="hero-split--bg-gradient"></div>
    {%- endif -%}

    <div class="hero-split--content">
      <h1 class="hero-split--heading">{{ section.settings.heading | newline_to_br }}</h1>
      <p class="hero-split--subheading">{{ section.settings.subheading }}</p>
      <a href="{{ section.settings.cta_link }}" class="btn btn--outline-dark">{{ section.settings.cta_text }}</a>
    </div>
  </div>

  <!-- RIGHT: produto centralizado no fundo cream -->
  <div class="hero-split--right">
    <div class="hero-split--product-wrap">
      {%- if section.settings.product_image != blank -%}
        {{ section.settings.product_image | image_url: width: 600 | image_tag: loading: 'eager', class: 'hero-split--product-img', alt: section.settings.product_name }}
      {%- else -%}
        <div class="hero-split--product-placeholder">
          <span>Product</span>
        </div>
      {%- endif -%}
      <p class="hero-split--product-name">{{ section.settings.product_name }}</p>
      <p class="hero-split--product-price">{{ section.settings.product_price }}</p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Split",
  "tag": "section",
  "class": "hero-split-section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Imagem de fundo (esquerda)" },
    { "type": "textarea", "id": "heading", "label": "Título (use Enter para quebras de linha)", "default": "FACE YOUR\nSKIN WITH\nHONESTY" },
    { "type": "textarea", "id": "subheading", "label": "Subtítulo", "default": "Clinical K-beauty ingredients. EU certified formulations. Prices that respect you." },
    { "type": "text", "id": "cta_text", "label": "Texto do botão", "default": "Shop Now" },
    { "type": "url", "id": "cta_link", "label": "Link do botão", "default": "/collections/all" },
    { "type": "image_picker", "id": "product_image", "label": "Foto do produto (direita)" },
    { "type": "text", "id": "product_name", "label": "Nome do produto", "default": "Niacinamide 5% Glow Gel" },
    { "type": "text", "id": "product_price", "label": "Preço do produto", "default": "£24.99" }
  ],
  "presets": [{ "name": "Hero Split" }]
}
{% endschema %}
