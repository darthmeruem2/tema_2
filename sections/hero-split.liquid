<div class="hero-split">
  <div class="hero-split--left">
    <span class="hero-split--label">{{ section.settings.label }}</span>

    <h1 class="hero-split--heading">{{ section.settings.heading }}</h1>

    <p class="hero-split--subheading">{{ section.settings.subheading }}</p>

    <div class="hero-split--ctas">
      <a href="{{ section.settings.cta_link }}" class="btn btn--primary">
        {{ section.settings.cta_text }}
      </a>
      <a href="{{ section.settings.secondary_link }}" class="btn btn--secondary">
        {{ section.settings.secondary_text }}
      </a>
    </div>

    <p class="hero-split--microcopy">No asterisks. No proprietary blends. Full INCI, always.</p>
  </div>

  <div class="hero-split--right">
    <div class="hero-split--image-wrap">
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', alt: section.settings.heading, class: 'hero-split--img' }}
      {%- else -%}
        <div class="img-placeholder">Hero Image</div>
      {%- endif -%}
    </div>

    <div class="hero-split--haru-badge" aria-hidden="true">☁️</div>

    <div class="hero-split--product-card">
      <div class="hero-split--product-badge">Bestseller</div>
      <div class="hero-split--product-info">
        <p class="hero-split--product-name">{{ section.settings.product_name }}</p>
        <div class="hero-split--product-prices">
          <span class="hero-split--product-price">{{ section.settings.product_price }}</span>
          <span class="hero-split--product-was">{{ section.settings.product_was }}</span>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Hero Split",
  "tag": "section",
  "class": "hero-split-section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Honest K-Beauty"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Same Lab. Same Results. £56 Less."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "We source the same active ingredients as luxury K-beauty. Then we show you exactly what's inside — concentrations included."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Primary CTA Text",
      "default": "See What's Inside"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Primary CTA Link",
      "default": "/collections/all"
    },
    {
      "type": "text",
      "id": "secondary_text",
      "label": "Secondary CTA Text",
      "default": "Discover the Collection"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary CTA Link",
      "default": "/collections/all"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image"
    },
    {
      "type": "text",
      "id": "product_name",
      "label": "Product Name (Card)",
      "default": "Niacinamide 5% Glow Gel"
    },
    {
      "type": "text",
      "id": "product_price",
      "label": "Product Price",
      "default": "£24.99"
    },
    {
      "type": "text",
      "id": "product_was",
      "label": "Product Was Price",
      "default": "£80.00"
    }
  ],
  "presets": [
    {
      "name": "Hero Split"
    }
  ]
}
{% endschema %}
