<div class="home-pillars">
  <div class="home-pillars--inner">
    {%- for block in section.blocks -%}
      {%- if block.type == 'pillar' -%}
        <div class="home-pillars--pillar" {{ block.shopify_attributes }}>
          {%- if block.settings.icon != blank -%}
            <div class="home-pillars--icon">{{ block.settings.icon }}</div>
          {%- endif -%}
          <h3 class="home-pillars--heading">{{ block.settings.heading }}</h3>
          <p class="home-pillars--text">{{ block.settings.text }}</p>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Home Pillars",
  "tag": "div",
  "class": "home-pillars-section",
  "max_blocks": 6,
  "blocks": [
    {
      "type": "pillar",
      "name": "Pillar",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (emoji or text)"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Home Pillars",
      "blocks": [
        {
          "type": "pillar",
          "settings": {
            "icon": "🔬",
            "heading": "No Decorative Ingredients",
            "text": "Every active in every SHIEH formula sits at its clinically validated concentration. We publish the numbers. You verify them."
          }
        },
        {
          "type": "pillar",
          "settings": {
            "icon": "✓",
            "heading": "EU & ECOCERT Certified",
            "text": "Third-party verified. ECOCERT certified formulas. GPSR compliant across the EU and UK. No asterisks on our safety claims."
          }
        },
        {
          "type": "pillar",
          "settings": {
            "icon": "🌿",
            "heading": "Seoul Lab. Honest Lab.",
            "text": "Formulated with South Korean cosmetic science — the same methodology behind the world's most effective skincare. Disclosed in full by Sora Yun."
          }
        }
      ]
    }
  ]
}
{% endschema %}
