{%- assign featured = all_products[section.settings.featured_product] -%}

<div class="hero--root">
  {%- if section.settings.image != blank -%}
    <div class="hero--bg">
      <img
        src="{{ section.settings.image | image_url: width: 1920 }}"
        alt="{{ section.settings.image.alt | default: section.settings.heading | escape }}"
        width="1920" height="960" loading="eager"
      >
    </div>
  {%- else -%}
    <div class="hero--bg hero--bg-placeholder"></div>
  {%- endif -%}

  <div class="hero--content">
    <div class="hero--text">
      {%- if section.settings.overline != blank -%}
        <p class="hero--overline">{{ section.settings.overline }}</p>
      {%- endif -%}
      <h1 class="hero--heading">{{ section.settings.heading | default: 'Face Your Skin With Us' }}</h1>
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link | default: routes.all_products_collection_url }}" class="hero--cta">
          {{ section.settings.button_label | upcase }}
        </a>
      {%- endif -%}
    </div>

    {%- if featured != blank -%}
      <div class="hero--product-card">
        {%- if featured.featured_image -%}
          <a href="{{ featured.url }}">
            <img
              src="{{ featured.featured_image | image_url: width: 400 }}"
              alt="{{ featured.featured_image.alt | default: featured.title | escape }}"
              width="400" height="400" loading="eager"
            >
          </a>
        {%- endif -%}
        <div class="hero--product-card-info">
          <p class="hero--product-name">{{ featured.title | upcase }}</p>
          <p class="hero--product-price">{{ featured.price | money }}</p>
        </div>
      </div>
    {%- endif -%}
  </div>

  <button class="hero--arrow hero--arrow-prev" aria-label="Previous">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
  </button>
  <button class="hero--arrow hero--arrow-next" aria-label="Next">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
  </button>
</div>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "class": "section-hero",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "text", "id": "overline", "label": "Overline (italic)", "default": "The Art of Skin Science." },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Face Your Skin With Us" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Explore" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "product", "id": "featured_product", "label": "Floating product card" }
  ],
  "presets": [{ "name": "Hero", "settings": { "heading": "Face Your Skin With Us", "overline": "The Art of Skin Science.", "button_label": "Explore" } }]
}
{% endschema %}
