<section class="ingredient-map">
  <div class="ingredient-map--header">
    {%- if section.settings.overline != blank -%}
      <span class="ingredient-map--overline">{{ section.settings.overline }}</span>
    {%- endif -%}
    <h2 class="ingredient-map--heading">{{ section.settings.heading }}</h2>
  </div>

  <div class="ingredient-map--body">

    <!-- SVG connector lines -->
    <svg
      class="ingredient-map--svg"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
      focusable="false"
    >
      <!-- Top-left to center -->
      <line class="ingredient-map--line" x1="20%" y1="20%" x2="50%" y2="50%" stroke-dasharray="6,4" />
      <!-- Top-right to center -->
      <line class="ingredient-map--line" x1="80%" y1="20%" x2="50%" y2="50%" stroke-dasharray="6,4" />
      <!-- Bottom-left to center -->
      <line class="ingredient-map--line" x1="20%" y1="80%" x2="50%" y2="50%" stroke-dasharray="6,4" />
      <!-- Bottom-right to center -->
      <line class="ingredient-map--line" x1="80%" y1="80%" x2="50%" y2="50%" stroke-dasharray="6,4" />
    </svg>

    <!-- Center product image -->
    <div class="ingredient-map--center">
      {%- if section.settings.center_image != blank -%}
        {{ section.settings.center_image | image_url: width: 400 | image_tag: loading: 'lazy', alt: section.settings.heading, class: 'ingredient-map--center-img' }}
      {%- else -%}
        <div class="img-placeholder ingredient-map--center-placeholder">Product</div>
      {%- endif -%}
    </div>

    <!-- Ingredient nodes -->
    {%- assign positions = "pos-tl,pos-tr,pos-bl,pos-br" | split: "," -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'ingredient' -%}
        {%- assign pos = positions[forloop.index0] -%}
        <div class="ingredient-map--node {{ pos }}" {{ block.shopify_attributes }}>
          <h3 class="ingredient-map--node-name">{{ block.settings.name }}</h3>
          <p class="ingredient-map--node-desc">{{ block.settings.description }}</p>
        </div>
      {%- endif -%}
    {%- endfor -%}

  </div>
</section>

{% schema %}
{
  "name": "Ingredient Map",
  "tag": "section",
  "class": "ingredient-map-section",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "overline",
      "label": "Overline",
      "default": "Key Actives"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What's Inside"
    },
    {
      "type": "image_picker",
      "id": "center_image",
      "label": "Center Product Image"
    }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Ingredient Name"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ingredient Map",
      "blocks": [
        {
          "type": "ingredient",
          "settings": {
            "name": "Niacinamide 5%",
            "description": "Clinically validated concentration for pore minimisation, sebum control, and evening skin tone. Published on every label."
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "name": "AHA Complex 10%",
            "description": "Glycolic and lactic acid blend at exfoliating-grade concentrations. Resurfaces without the guesswork."
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "name": "Centella Asiatica 3%",
            "description": "Korean skincare cornerstone — anti-inflammatory, barrier-repairing, and backed by decades of clinical use."
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "name": "Hyaluronic Acid 1%",
            "description": "Multi-weight molecule at full hydrating capacity. No diluted proprietary blends. Pure, disclosed, effective."
          }
        }
      ]
    }
  ]
}
{% endschema %}
