<div class="main-page--root" style="max-width:480px;">

  <h1 class="main-page--title">CRIAR CONTA</h1>

  {%- if form.errors -%}
    <div style="padding:12px 16px; background:#fff0f0; border:1px solid #f5c6c6; margin-bottom:var(--layout--spacing-medium);">
      <p style="font-size:11px; color:#c0392b; text-transform:uppercase;">
        {%- for error in form.errors -%}
          {{ form.errors.messages[error] }}<br>
        {%- endfor -%}
      </p>
    </div>
  {%- endif -%}

  {%- form 'create_customer' -%}
    <div style="display:flex; flex-direction:column; gap:16px;">

      <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
        <div>
          <label style="display:block; font-size:10px; text-transform:uppercase; letter-spacing:0.08em; margin-bottom:6px;" for="FirstName">
            Nome
          </label>
          <input
            type="text"
            name="customer[first_name]"
            id="FirstName"
            autocomplete="given-name"
            style="width:100%; height:var(--input--height); padding:var(--input--padding); border:1px solid rgba(0,0,0,0.15); font-family:var(--font--paragraph--family); font-size:var(--font--nav--size); text-transform:uppercase; background:transparent; outline:none; box-sizing:border-box;"
            placeholder="NOME"
          >
        </div>
        <div>
          <label style="display:block; font-size:10px; text-transform:uppercase; letter-spacing:0.08em; margin-bottom:6px;" for="LastName">
            Sobrenome
          </label>
          <input
            type="text"
            name="customer[last_name]"
            id="LastName"
            autocomplete="family-name"
            style="width:100%; height:var(--input--height); padding:var(--input--padding); border:1px solid rgba(0,0,0,0.15); font-family:var(--font--paragraph--family); font-size:var(--font--nav--size); text-transform:uppercase; background:transparent; outline:none; box-sizing:border-box;"
            placeholder="SOBRENOME"
          >
        </div>
      </div>

      <div>
        <label style="display:block; font-size:10px; text-transform:uppercase; letter-spacing:0.08em; margin-bottom:6px;" for="Email">
          Email
        </label>
        <input
          type="email"
          name="customer[email]"
          id="Email"
          autocomplete="email"
          autocorrect="off"
          autocapitalize="off"
          style="width:100%; height:var(--input--height); padding:var(--input--padding); border:1px solid rgba(0,0,0,0.15); font-family:var(--font--paragraph--family); font-size:var(--font--nav--size); text-transform:uppercase; background:transparent; outline:none; box-sizing:border-box;"
          placeholder="SEU@EMAIL.COM"
        >
      </div>

      <div>
        <label style="display:block; font-size:10px; text-transform:uppercase; letter-spacing:0.08em; margin-bottom:6px;" for="CreatePassword">
          Senha
        </label>
        <input
          type="password"
          name="customer[password]"
          id="CreatePassword"
          autocomplete="new-password"
          style="width:100%; height:var(--input--height); padding:var(--input--padding); border:1px solid rgba(0,0,0,0.15); font-family:var(--font--paragraph--family); font-size:var(--font--nav--size); text-transform:uppercase; background:transparent; outline:none; box-sizing:border-box;"
          placeholder="SENHA"
        >
      </div>

      <button type="submit" class="btn btn--1">CRIAR CONTA</button>

    </div>
  {%- endform -%}

  <div style="margin-top:var(--layout--spacing-medium); padding-top:var(--layout--spacing-medium); border-top:1px solid rgba(0,0,0,0.06);">
    <p style="font-size:11px; text-transform:uppercase; color:var(--color--gray); margin-bottom:12px;">
      Já tem conta?
    </p>
    <a href="/account/login" class="btn btn--2">ENTRAR</a>
  </div>

</div>

{% schema %}
{
  "name": "Register",
  "tag": "section",
  "settings": []
}
{% endschema %}
