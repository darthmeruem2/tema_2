<div class="info-boxes--root">
  <div class="info-boxes--grid">

    {%- for block in section.blocks -%}
      {%- if block.type == 'box' -%}
        <div class="info-boxes--item" {{ block.shopify_attributes }}>

          {%- if block.settings.icon != blank -%}
            <div class="info-boxes--item--icon" aria-hidden="true">{{ block.settings.icon }}</div>
          {%- endif -%}

          {%- if block.settings.heading != blank -%}
            <h3 class="info-boxes--item--title">{{ block.settings.heading | upcase }}</h3>
          {%- endif -%}

          {%- if block.settings.text != blank -%}
            <p class="info-boxes--item--text">{{ block.settings.text | upcase }}</p>
          {%- endif -%}

        </div>
      {%- endif -%}
    {%- endfor -%}

  </div>
</div>

{% schema %}
{
  "name": "Info Boxes",
  "tag": "section",
  "class": "section-info-boxes",
  "blocks": [
    {
      "type": "box",
      "name": "Info box",
      "limit": 5,
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (emoji or symbol)",
          "default": "✦"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Free Delivery"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Enjoy free shipping on all orders over £60."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Info Boxes",
      "blocks": [
        {
          "type": "box",
          "settings": {
            "icon": "🚚",
            "heading": "Free Delivery",
            "text": "Enjoy free shipping on all orders over £60."
          }
        },
        {
          "type": "box",
          "settings": {
            "icon": "↩",
            "heading": "Easy Returns",
            "text": "Not in love? Return within 30 days, no questions asked."
          }
        },
        {
          "type": "box",
          "settings": {
            "icon": "⚡",
            "heading": "Fast Dispatch",
            "text": "Orders placed before 2pm ship the same business day."
          }
        },
        {
          "type": "box",
          "settings": {
            "icon": "✓",
            "heading": "Quality Guaranteed",
            "text": "Dermatologist-tested. Safe for all skin types."
          }
        },
        {
          "type": "box",
          "settings": {
            "icon": "🌿",
            "heading": "Eco-Friendly",
            "text": "Sustainable packaging. Cruelty-free certified. Always."
          }
        }
      ]
    }
  ]
}
{% endschema %}
