{%- assign blog_handle = section.settings.blog | default: 'news' -%}
{%- assign featured_blog = blogs[blog_handle] -%}

<div class="blog-grid--root">
  {%- if section.settings.heading != blank -%}
    <p class="blog-grid--heading">{{ section.settings.heading | upcase }}</p>
  {%- endif -%}

  <div class="blog-grid--grid">
    {%- if featured_blog != blank and featured_blog.articles.size > 0 -%}
      {%- for article in featured_blog.articles limit: 3 -%}
        <a href="{{ article.url }}" class="blog-card--root">
          <div class="blog-card--image">
            {%- if article.image -%}
              <img
                src="{{ article.image | image_url: width: 800 }}"
                alt="{{ article.image.alt | default: article.title | escape }}"
                width="800" height="600" loading="lazy"
              >
            {%- else -%}
              <div class="blog-card--image-placeholder"></div>
            {%- endif -%}
          </div>
          {%- if article.tags.size > 0 -%}
            <p class="blog-card--category">{{ article.tags | first }}</p>
          {%- endif -%}
          <h3 class="blog-card--title">{{ article.title }}</h3>
          <p class="blog-card--author">By {{ article.author }}</p>
        </a>
      {%- endfor -%}
    {%- else -%}
      {%- for i in (1..3) -%}
        <div class="blog-card--root">
          <div class="blog-card--image">
            <div class="blog-card--image-placeholder"></div>
          </div>
          {%- if i == 1 -%}<p class="blog-card--category">Skincare</p>
          {%- elsif i == 2 -%}<p class="blog-card--category">Ingredients</p>
          {%- else -%}<p class="blog-card--category">Beauty Tips</p>
          {%- endif -%}
          <h3 class="blog-card--title">
            {%- if i == 1 -%}New refreshing type for delicate skin
            {%- elsif i == 2 -%}The best new care brands coming soon
            {%- else -%}How to control shine face with natural oil
            {%- endif -%}
          </h3>
          <p class="blog-card--author">By SHIEH Editorial</p>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Blog Grid",
  "tag": "section",
  "class": "section-blog-grid",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "From the Journal" },
    { "type": "blog", "id": "blog", "label": "Blog" }
  ],
  "presets": [{ "name": "Blog Grid", "settings": { "heading": "From the Journal" } }]
}
{% endschema %}
